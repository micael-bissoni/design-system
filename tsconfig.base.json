{
  "compileOnSave": false,
  "compilerOptions": {
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "es2022",
    "module": "preserve",
    "lib": [
      "es2020",
      "dom"
    ],
    "baseUrl": ".",
    "paths": {
      "@trevvo/design-system/components": [
        "ui-components/src/index.ts"
      ],
      "@trevvo/design-system/tokens": [
        "ui-components/tokens/src/index.ts"
      ],
    },
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
    "tmp"
  ]
}