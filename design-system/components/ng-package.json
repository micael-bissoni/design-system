{
  "$schema": "../../node_modules/ng-packagr/ng-package.schema.json",
  "dest": "../../dist/components",
  "lib": {
    "entryFile": "src/index.ts"
  },
  "assets": [
    {
      "glob": "**/*.css",
      "input": "./../dist/design-system/browser/tokens",
      "output": "tokens/web"
    },
    {
      "glob": "**/*.json",
      "input": "./../dist/design-system/browser/assets",
      "output": "assets"
    }
  ]
}