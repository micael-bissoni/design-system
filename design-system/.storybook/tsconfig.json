{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@trevvo/design-system": [
        "../src/index.ts"
      ],
      "@trevvo/design-system/components": [
        "../components/src/index.ts"
      ],
      "@trevvo/design-system/tokens": [
        "../tokens/src/index.ts"
      ]
    }
  },
  "exclude": [
    "../../**/*.spec.ts"
  ],
  "include": [
    "../components/**/*.stories.ts",
    "../components/**/*.stories.js",
    "../components/**/*.stories.jsx",
    "../components/**/*.stories.tsx",
    "../components/**/*.stories.mdx",
    "*.js",
    "*.ts"
  ]
}